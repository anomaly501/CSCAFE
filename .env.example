# Copy this file to .env and fill in your values
# Get DB URL from: https://neon.tech → your project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# API Key for authenticating admin write operations (POST/PUT/DELETE)
# If not set, a random key is generated on each server start (printed in console)
API_KEY=your-secure-api-key-here

# Comma-separated list of allowed CORS origins (optional)
# If not set, defaults to http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
